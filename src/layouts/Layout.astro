---
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  type?: 'website' | 'article';
  publishDate?: Date;
  modifiedDate?: Date;
  author?: string;
  keywords?: string[];
  wordCount?: number;
  section?: string;
  noindex?: boolean;
}

const {
  title,
  description = "Bhuvan — writer, builder, follower of ideas too far",
  image,
  imageAlt,
  type = 'website',
  publishDate,
  modifiedDate,
  author = 'Bhuvan',
  keywords = [],
  wordCount,
  section,
  noindex = false,
} = Astro.props;

const siteUrl = 'https://bebhuvan.com';
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const defaultImage = image || '/profile-pic.webp';
const fullImageUrl = new URL(defaultImage, Astro.site);
const ogImageAlt = imageAlt || `${title} — Bhuvan`;

// Build JSON-LD as a @graph so a single script element describes the page,
// the article (when applicable), the author, and the website.
const person = {
  '@type': 'Person',
  '@id': `${siteUrl}/#person`,
  name: author,
  url: siteUrl,
  sameAs: [
    'https://twitter.com/bhuvanesh2007',
  ],
};

const website = {
  '@type': 'WebSite',
  '@id': `${siteUrl}/#website`,
  url: siteUrl,
  name: 'Bhuvan',
  description: 'Bhuvan — writer, builder, follower of ideas too far',
  inLanguage: 'en',
  publisher: { '@id': `${siteUrl}/#person` },
};

const webpage = {
  '@type': 'WebPage',
  '@id': `${canonicalURL}#webpage`,
  url: canonicalURL.toString(),
  name: title,
  description,
  inLanguage: 'en',
  isPartOf: { '@id': `${siteUrl}/#website` },
  primaryImageOfPage: { '@id': `${canonicalURL}#primaryimage` },
};

const primaryImage = {
  '@type': 'ImageObject',
  '@id': `${canonicalURL}#primaryimage`,
  url: fullImageUrl.toString(),
  contentUrl: fullImageUrl.toString(),
  caption: ogImageAlt,
};

const article = type === 'article' && publishDate ? {
  '@type': 'BlogPosting',
  '@id': `${canonicalURL}#article`,
  isPartOf: { '@id': `${canonicalURL}#webpage` },
  mainEntityOfPage: { '@id': `${canonicalURL}#webpage` },
  headline: title,
  name: title,
  description,
  image: { '@id': `${canonicalURL}#primaryimage` },
  datePublished: publishDate.toISOString(),
  dateModified: (modifiedDate || publishDate).toISOString(),
  author: { '@id': `${siteUrl}/#person` },
  publisher: { '@id': `${siteUrl}/#person` },
  inLanguage: 'en',
  url: canonicalURL.toString(),
  ...(wordCount ? { wordCount } : {}),
  ...(keywords.length ? { keywords: keywords.join(', ') } : {}),
  ...(section ? { articleSection: section } : {}),
} : null;

const graph = [person, website, webpage, primaryImage, ...(article ? [article] : [])];
const jsonLd = { '@context': 'https://schema.org', '@graph': graph };
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="light only" />
    <meta name="theme-color" content="#FEFDFB" />
    <meta name="format-detection" content="telephone=no" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Icons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/profile-pic-160.webp" />

    <!-- Fonts are self-hosted via fontsource and bundled into our CSS.
         No external font CDN, no extra DNS lookup. -->

    <!-- SEO -->
    <meta name="author" content={author} />
    <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1'} />
    {keywords.length > 0 && <meta name="keywords" content={keywords.join(', ')} />}

    <!-- RSS -->
    <link rel="alternate" type="application/rss+xml" title="Bhuvan — Writing" href="/rss.xml" />
    <link rel="alternate" type="application/rss+xml" title="Bhuvan — Marginalia" href="/updates-rss.xml" />
    <link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={fullImageUrl} />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Bhuvan" />
    <meta property="og:locale" content="en_US" />
    {publishDate && <meta property="article:published_time" content={publishDate.toISOString()} />}
    {(modifiedDate || publishDate) && type === 'article' && (
      <meta property="article:modified_time" content={(modifiedDate || publishDate)!.toISOString()} />
    )}
    {type === 'article' && <meta property="article:author" content={author} />}
    {type === 'article' && section && <meta property="article:section" content={section} />}
    {type === 'article' && keywords.map((k) => <meta property="article:tag" content={k} />)}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={Astro.url} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={fullImageUrl} />
    <meta name="twitter:image:alt" content={ogImageAlt} />
    <meta name="twitter:creator" content="@bhuvanesh2007" />
    <meta name="twitter:site" content="@bhuvanesh2007" />

    <!-- JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <slot />
  </body>
</html>
