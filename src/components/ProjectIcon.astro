---
export interface Props {
  name: string;
  size?: number;
}

const { name, size = 28 } = Astro.props;

const icons: Record<string, string> = {
  'scroll-text': `<path d="M8 21h12a2 2 0 0 0 2-2v-2H10v2a2 2 0 1 1-4 0V5a2 2 0 0 0-2 2v2h12V7a2 2 0 0 0-2-2H6" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M11 13H7M15 9H7" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>`,
  'languages': `<path d="m5 8 6 6M4 14l6-6 2-3M2 5h12M7 2h1" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="m22 22-5-10-5 10M14 18h6" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>`,
  'lamp': `<path d="M8 2h8l4 10H4L8 2Z" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M12 12v6M8 18h8" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M10 22h4" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>`,
  'rabbit': `<path d="M13 16a3 3 0 0 1 2.24 1M18 12h.01" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M18 21a4 4 0 0 0-4-4 4 4 0 0 0-4 4" fill="none" stroke="currentColor" stroke-width="1.5"/><path d="M8.65 3C6.26 4.21 5 7.1 5 9.5 5 14 8 16 12 16s7-2 7-6.5c0-2.4-1.26-5.29-3.65-6.5" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M14 4.5C14 3 15.23 1 17 1c.83 2 1 4 0 5.5M10 4.5C10 3 8.77 1 7 1c-.83 2-1 4 0 5.5" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>`,
  'mic': `<path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z" fill="none" stroke="currentColor" stroke-width="1.5"/><path d="M19 10v2a7 7 0 0 1-14 0v-2M12 19v3M8 22h8" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>`,
  'rss': `<path d="M4 11a9 9 0 0 1 9 9M4 4a16 16 0 0 1 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><circle cx="5" cy="19" r="1" fill="currentColor"/>`,
  'fire': `<path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>`,
  'sparkles': `<path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M5 3v4M19 17v4M3 5h4M17 19h4" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>`,
};

const svgContent = icons[name] || icons['sparkles'];
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 24 24"
  class="project-icon"
  set:html={svgContent}
/>

<style>
  .project-icon {
    color: var(--flame);
    flex-shrink: 0;
    transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  }
</style>
