---
import { getCollection } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

export const getStaticPaths: GetStaticPaths = async () => {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
};

const { post } = Astro.props;
const { Content } = await post.render();

const allPosts = (await getCollection('blog'))
  .filter(p => !p.data.draft && p.slug !== post.slug)
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 3);

const date = post.data.publishDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
const tags = post.data.tags || [];
const wordCount = post.body ? post.body.split(/\s+/).filter(Boolean).length : 0;
---

<Layout
  title={`${post.data.title} — Bhuvan`}
  description={post.data.description}
  image={post.data.image}
  type="article"
  publishDate={post.data.publishDate}
  keywords={tags}
>
  <Nav active="writing" />

  <div class="wrap">
    <div class="col">
      <div class="article-header">
        <!-- Margin metadata (wide screens only) -->
        <div class="ah-margin">
          <span class="ah-label">about this essay</span>
          <span class="ah-row">{date}</span>
          <span class="ah-row">{post.data.readingTime || ''}{post.data.readingTime && wordCount > 0 ? ' · ' : ''}{wordCount > 0 ? `${wordCount.toLocaleString()} words` : ''}</span>
          <br />
          {tags.map(tag => (
            <span class="ah-tag">{tag}</span>
          ))}
        </div>

        <div class="breadcrumb">
          <a href="/">Bhuvan</a>
          <span class="sep">/</span>
          <a href="/writing">Writing</a>
          <span class="sep">/</span>
          <span>essay</span>
        </div>

        {post.data.draft && (
          <div class="draft-badge">living draft</div>
        )}

        <h1 class="article-title">{post.data.title}</h1>

        {post.data.description && (
          <p class="article-lede">{post.data.description}</p>
        )}
      </div>

      {post.data.image && (
        <div class="article-image">
          <img src={post.data.image} alt={post.data.imageCaption || post.data.title} />
          {post.data.imageCaption && <span class="ai-caption">{post.data.imageCaption}</span>}
        </div>
      )}

      <div class="article-body">
        <Content />
      </div>

      {tags.length > 0 && (
        <div class="article-tags">
          {tags.map(tag => (
            <span class="tag-pill">{tag}</span>
          ))}
        </div>
      )}

      {allPosts.length > 0 && (
        <div class="article-end">
          <span class="ae-label">more like this &rarr;</span>
          {allPosts.map(p => (
            <div class="related-item">
              <a href={`/blog/${p.slug}/`}>{p.data.title}</a>
              <span>{p.data.publishDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
            </div>
          ))}
        </div>
      )}

      <Footer hand="Thanks for reading to the end. That's rare and I appreciate it." />
    </div>
  </div>
</Layout>

<style>
  /* Article header */
  .article-header { padding: 10rem 0 3.5rem; position: relative; border-bottom: 1px solid var(--rule-faint); margin-bottom: 3.5rem; }

  /* Margin metadata */
  .ah-margin { position: absolute; right: calc(100% + var(--gap)); top: 10rem; width: var(--margin); text-align: right; }
  .ah-label { font-family: var(--hand); font-size: 0.95rem; color: var(--flame-warm); display: block; margin-bottom: 0.8rem; transform: rotate(-0.5deg); }
  .ah-row { font-family: var(--mono); font-size: 0.54rem; color: var(--ink-faint); display: block; line-height: 2.1; }
  .ah-tag { display: inline-block; font-family: var(--mono); font-size: 0.5rem; color: var(--ink-light); background: var(--paper-tint); border: 1px solid var(--rule-faint); padding: 0.1rem 0.5rem; border-radius: 100px; margin-top: 0.5rem; margin-right: 0.2rem; transition: border-color 0.3s, color 0.3s; }
  .ah-tag:hover { border-color: var(--flame-line); color: var(--flame); }

  /* Breadcrumb */
  .breadcrumb { font-family: var(--mono); font-size: 0.54rem; color: var(--ink-ghost); margin-bottom: 1.8rem; display: flex; align-items: center; gap: 0.5rem; }
  .breadcrumb a { color: var(--ink-faint); text-decoration: none; transition: color 0.3s; }
  .breadcrumb a:hover { color: var(--flame); }
  .breadcrumb .sep { color: var(--rule); }

  /* Draft badge */
  .draft-badge { display: inline-flex; align-items: center; gap: 0.3rem; font-family: var(--mono); font-size: 0.52rem; color: var(--flame); background: var(--flame-wash); padding: 0.15rem 0.55rem; border-radius: 3px; margin-bottom: 1.3rem; }
  .draft-badge::before { content: ''; width: 5px; height: 5px; border-radius: 50%; background: var(--flame); animation: pulse 2s ease infinite; }

  /* Title and lede */
  .article-title { font-family: var(--serif); font-size: clamp(1.85rem, 3.2vw, 2.6rem); font-weight: 400; line-height: 1.14; letter-spacing: -0.025em; color: var(--ink); margin-bottom: 1.6rem; font-variation-settings: 'opsz' 48; }
  .article-lede { font-family: var(--serif); font-size: 1.12rem; font-weight: 300; line-height: 1.72; color: var(--ink-soft); max-width: 520px; font-variation-settings: 'opsz' 24; }

  /* Article image */
  .article-image { margin-bottom: 3.5rem; }
  .article-image img { width: 100%; border-radius: 6px; }
  .ai-caption { font-family: var(--mono); font-size: 0.54rem; color: var(--ink-faint); margin-top: 0.5rem; display: block; }

  /* Article body */
  .article-body { position: relative; }
  .article-body :global(p) { font-family: var(--serif); font-size: 1.05rem; font-weight: 300; line-height: 1.84; color: var(--ink-mid); margin-bottom: 1.5rem; font-variation-settings: 'opsz' 14; }
  .article-body > :global(p:first-of-type::first-letter) { font-size: 3.2rem; font-weight: 600; float: left; line-height: 0.85; margin-right: 0.08em; margin-top: 0.05em; padding-right: 0.02em; color: var(--ink); font-variation-settings: 'opsz' 72; }
  .article-body :global(blockquote p::first-letter) { float: none !important; font-size: inherit !important; font-weight: inherit !important; margin: 0 !important; padding: 0 !important; }
  .article-body :global(li p::first-letter) { float: none !important; font-size: inherit !important; font-weight: inherit !important; margin: 0 !important; padding: 0 !important; }
  .article-body :global(p strong) { font-weight: 500; color: var(--ink); }
  .article-body :global(h2) { font-family: var(--serif); font-size: 1.3rem; font-weight: 500; letter-spacing: -0.02em; color: var(--ink); margin: 3rem 0 1.2rem; font-variation-settings: 'opsz' 24; }
  .article-body :global(h3) { font-family: var(--serif); font-size: 1.1rem; font-weight: 500; letter-spacing: -0.01em; margin: 2.5rem 0 1rem; }

  /* Blockquote */
  .article-body :global(blockquote) { margin: 2rem 0; padding: 1.2rem 0 1.2rem 1.5rem; border-left: 2px solid var(--flame-line); }
  .article-body :global(blockquote p) { font-style: italic; color: var(--ink-soft); font-size: 1rem; line-height: 1.75; font-variation-settings: 'opsz' 18; }
  .article-body :global(blockquote p:last-child) { margin-bottom: 0; }

  /* Links */
  .article-body :global(a) { color: var(--flame); text-decoration: none; border-bottom: 1px solid var(--flame-line); transition: border-color 0.2s; }
  .article-body :global(a:hover) { border-color: var(--flame); }

  /* Lists */
  .article-body :global(ul), .article-body :global(ol) { padding-left: 1.5rem; margin-bottom: 1.5rem; }
  .article-body :global(li) { font-size: 1.05rem; font-weight: 300; line-height: 1.84; color: var(--ink-mid); margin-bottom: 0.5rem; }

  /* Code */
  .article-body :global(code) { font-family: var(--mono); font-size: 0.88rem; background: var(--paper-tint); padding: 0.15rem 0.4rem; border-radius: 3px; }
  .article-body :global(pre) { background: var(--paper-tint); border: 1px solid var(--rule-faint); border-radius: 6px; padding: 1.5rem; overflow-x: auto; margin: 2rem 0; }
  .article-body :global(pre code) { background: none; padding: 0; }

  /* HR */
  .article-body :global(hr) { border: none; margin: 3rem 0; height: 1px; background: linear-gradient(90deg, transparent, var(--rule-faint) 20%, var(--rule-faint) 80%, transparent); }

  /* Images */
  .article-body :global(img) { max-width: 100%; border-radius: 6px; margin: 2rem 0; }

  /* Inline highlight */
  .article-body :global(mark) { background: var(--flame-wash); color: var(--ink-mid); border-radius: 2px; padding: 0.05em 0.2em; }

  /* Callout blocks */
  .article-body :global(.callout) { margin: 2.5rem 0; padding: 1.2rem 1.5rem 1.2rem 1.4rem; border-left: 3px solid var(--flame-line); background: var(--paper-tint); border-radius: 0 6px 6px 0; position: relative; transition: border-left-color 0.3s; }
  .article-body :global(.callout:hover) { border-left-color: var(--flame); }
  .article-body :global(.callout p) { font-size: 0.9rem !important; font-weight: 300; color: var(--ink-soft); margin-bottom: 0 !important; }
  .article-body :global(.callout p::first-letter) { float: none !important; font-size: inherit !important; }

  /* Sidenotes */
  .article-body :global(.sn) { float: right; clear: right; margin-right: calc(-1 * (var(--margin) + var(--gap))); width: calc(var(--margin) - 0.5rem); font-family: var(--hand); font-size: 1rem; color: var(--ink-soft); line-height: 1.45; padding-left: 0.65rem; border-left: 2px solid var(--flame-line); margin-top: 0.25rem; margin-bottom: 0.5rem; transform: rotate(0.4deg); }

  /* Inline annotation */
  .article-body :global(.an) { border-bottom: 1.5px dashed var(--flame-line); cursor: default; transition: border-color 0.3s; }
  .article-body :global(.an:hover) { border-color: var(--flame); }

  /* Tags */
  .article-tags { margin-top: 2rem; display: flex; gap: 0.5rem; flex-wrap: wrap; }

  /* Article end */
  .article-end { margin-top: 5rem; padding-top: 3rem; border-top: 1px solid var(--rule-faint); }
  .ae-label { font-family: var(--hand); font-size: 1.1rem; color: var(--ink-faint); display: block; margin-bottom: 1.5rem; }
  .related-item { padding: 1rem 0; border-bottom: 1px solid var(--rule-faint); display: flex; justify-content: space-between; align-items: baseline; gap: 2rem; }
  .related-item a { font-family: var(--serif); font-size: 1rem; font-weight: 400; color: var(--ink); text-decoration: none; border-bottom: 1px solid var(--rule-faint); transition: color 0.2s, border-color 0.2s; }
  .related-item a:hover { color: var(--flame); border-color: var(--flame-line); }
  .related-item span { font-family: var(--mono); font-size: 0.54rem; color: var(--ink-faint); flex-shrink: 0; }

  /* Responsive */
  @media (max-width: 1400px) {
    .ah-margin { display: none; }
    .article-body :global(.sn) { float: none; width: auto; margin-right: 0; display: block; clear: both; margin: 0.4rem 0 0.9rem; padding: 0.6rem 1rem; background: var(--paper-tint); border-radius: 0 6px 6px 0; transform: none; }
  }
  @media (max-width: 700px) {
    .article-header { padding: 7rem 0 2.5rem; }
    .article-title { font-size: clamp(1.5rem, 7vw, 1.9rem); }
  }
</style>
