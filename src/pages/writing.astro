---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import PageHeader from '../components/PageHeader.astro';

const posts = (await getCollection('blog'))
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

const postsByYear = posts.reduce((acc, post) => {
  const year = post.data.publishDate.getFullYear();
  if (!acc[year]) acc[year] = [];
  acc[year].push(post);
  return acc;
}, {} as Record<number, typeof posts>);

const years = Object.keys(postsByYear).map(Number).sort((a, b) => b - a);
const totalPosts = posts.length;
const draftCount = (await getCollection('blog')).filter(p => p.data.draft).length;
---

<Layout title="Writing — Bhuvan" description="Long-form essays — the workshop, not the gallery.">
  <Nav active="writing" />
  <main class="wrap">
    <div class="col">
      <PageHeader
        numeral="I"
        title='Long-Form <em>Writing</em>'
        subtitleFont="serif-italic"
        subtitle="the workshop, not the gallery — nothing here is quite finished"
        count={`${totalPosts} essays · ${draftCount} living drafts`}
      />

      {years.map(year => (
        <section>
          <div class="year-h">{year}<span class="yh-count">{postsByYear[year].length} essay{postsByYear[year].length !== 1 ? 's' : ''}</span></div>
          {postsByYear[year].map(post => (
            <div class="essay-row">
              <a href={`/blog/${post.slug}/`} class="er-title">{post.data.title}</a>
              {post.data.description && <div class="er-excerpt">{post.data.description}</div>}
              <span class="er-meta">
                {post.data.publishDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}
                {post.data.tags?.[0] && <span class="er-tag"> · {post.data.tags[0]}</span>}
                {post.data.draft && <span class="er-badge">living draft</span>}
              </span>
            </div>
          ))}
        </section>
      ))}
    </div>
  </main>
  <Footer
    meta={`Zerodha · Bangalore · The Internet<br>${totalPosts} essays and counting. Most of them unfinished. All of them honest.`}
    hand="Writing is just thinking with better posture."
  />
</Layout>

<style>
  .essay-row {
    padding: 1.1rem 0;
    border-bottom: 1px solid var(--rule-faint);
    border-left: 2px solid transparent;
    padding-left: 1rem;
    margin-left: -1rem;
    transition: border-left-color 0.25s var(--ease);
  }

  .essay-row:hover {
    border-left-color: var(--flame-line);
  }

  .essay-row:last-child {
    border-bottom: none;
  }

  .er-title {
    font-family: var(--serif);
    font-size: 1.05rem;
    font-weight: 400;
    color: var(--ink);
    text-decoration: none;
    line-height: 1.35;
    letter-spacing: -0.01em;
    display: block;
    transition: color 0.2s;
    font-variation-settings: 'opsz' 16;
  }

  .er-title:hover {
    color: var(--flame);
  }

  .er-excerpt {
    font-family: var(--serif);
    font-size: 0.88rem;
    font-weight: 300;
    font-style: italic;
    color: var(--ink-light);
    line-height: 1.55;
    margin-top: 0.25rem;
    max-width: 520px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    font-variation-settings: 'opsz' 14;
  }

  .er-meta {
    font-family: var(--mono);
    font-size: 0.6rem;
    color: var(--ink-light);
    display: block;
    margin-top: 0.3rem;
  }

  .er-tag {
    font-family: var(--hand);
    font-size: 1.05rem;
    color: var(--flame-warm);
    opacity: 0.55;
  }

  .er-badge {
    font-family: var(--mono);
    font-size: 0.55rem;
    color: var(--flame);
    background: var(--flame-wash);
    padding: 0.12rem 0.5rem;
    border-radius: 3px;
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    margin-left: 0.5rem;
  }

  .er-badge::before {
    content: '';
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--flame);
    animation: pulse 2s ease infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.2; }
  }
</style>
