---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Interstitial from '../components/Interstitial.astro';
import { aggregateRSSFeeds } from '../utils/rss-aggregator';

const blogPosts = (await getCollection('blog'))
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

// Quotes for the rotator. Pure CSS cycler — no JS.
const quotes = [
  {
    text: 'It is not that we have a short time to live, but that we waste a great deal of it.',
    by: 'Seneca, Letter I',
  },
  {
    text: 'I have always imagined that Paradise will be a kind of library.',
    by: 'Borges, Ficciones',
  },
  {
    text: 'A classic is a book that has never finished saying what it has to say.',
    by: 'Italo Calvino',
  },
  {
    text: 'How we spend our days is, of course, how we spend our lives.',
    by: 'Annie Dillard, The Writing Life',
  },
  {
    text: 'We are made of stories, not atoms.',
    by: 'Muriel Rukeyser',
  },
];

const featuredPost = blogPosts[0];
const morePosts = blogPosts.slice(1, 5);

const updates = (await getCollection('updates'))
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 3);

const projects = (await getCollection('projects'))
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99))
  .slice(0, 3);

let books: any[] = [];
try {
  books = (await getCollection('books'))
    .sort((a, b) => (b.data.year ?? 0) - (a.data.year ?? 0))
    .slice(0, 4);
} catch (e) {}

const featuredBook = books[0];
const otherBooks = books.slice(1, 4);

let rssItems: any[] = [];
try {
  rssItems = (await aggregateRSSFeeds(4));
} catch (e) {}

const coverStyles: Record<string, { bg: string; spine: string }> = {
  flame: { bg: 'linear-gradient(170deg, #B84430 0%, #C45638 45%, #9A3A28 100%)', spine: '#7A2E1E' },
  blue:  { bg: 'linear-gradient(170deg, #2E4B78 0%, #3D6098 45%, #253E68 100%)', spine: '#1C3050' },
  green: { bg: 'linear-gradient(170deg, #336B45 0%, #448B5A 45%, #2A5838 100%)', spine: '#1E4030' },
  gold:  { bg: 'linear-gradient(170deg, #8B6E35 0%, #A8864A 45%, #73592A 100%)', spine: '#5A4520' },
};
const colorKeys = ['flame', 'blue', 'green', 'gold'];

const fmtFull = (d: Date) => d.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
const fmtShort = (d: Date) => d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
---

<Layout title="Bhuvan — The Folio">
  <Nav />

  <!-- ============================================================
       MASTHEAD
       ============================================================ -->
  <div class="wrap">
    <div class="col">
      <header class="masthead">
        <div class="masthead-hero">
          <img
            src="/blog-images/Bhuvan profile pic.webp"
            alt="Bhuvan"
            class="masthead-photo"
            width="88"
            height="88"
            loading="eager"
            fetchpriority="high"
            decoding="async"
          />
          <h1 class="nameplate">
            Bhuvan<span class="np-stop">.</span>
          </h1>
        </div>

        <div class="masthead-rule" aria-hidden="true"></div>

        <p class="strapline">
          Doer of random things, diver of weird rabbit holes,<br />
          sharer of fascinating things, writer of things nobody reads.
        </p>

        <!-- colophon: day / now / made rows -->
        <dl class="bio">
          <div class="bio-row">
            <dt>Day</dt>
            <dd>Working at <a href="https://zerodha.com">Zerodha</a> on markets, data, and curation.</dd>
          </div>
          <div class="bio-row">
            <dt>Now</dt>
            <dd>Lost in all the treasures hiding in the public domain &mdash; and what on earth to do with them.</dd>
          </div>
          <div class="bio-row">
            <dt>Made</dt>
            <dd class="bio-made">
              {projects.map((p, i) => (
                <>
                  <a href={p.data.link || '#'}>{p.data.url || p.data.title}</a>{i < projects.length - 1 && <span class="sep" aria-hidden="true">,</span>}
                </>
              ))}
            </dd>
          </div>
        </dl>
      </header>

      <!-- Cover ends, magazine begins. A short hairline break that
           marks the transition from centered frontispiece to the
           left-aligned reading content. -->
      <div class="masthead-break" aria-hidden="true"></div>
    </div>
  </div>

  <!-- ============================================================
       I. THE FEATURED ESSAY — magazine cover treatment
       ============================================================ -->
  <div class="wrap">
    <div class="col">
      {featuredPost && (
        <article class="featured">
          <!-- left margin: dateline + reading time + a single hand bracket -->
          <aside class="featured-meta">
            <span class="fm-kicker">The Essay</span>
            <span class="fm-date">{fmtFull(featuredPost.data.publishDate)}</span>
            {featuredPost.data.readingTime && (
              <span class="fm-time">{featuredPost.data.readingTime}</span>
            )}
            <svg class="fm-bracket" viewBox="0 0 28 80" aria-hidden="true">
              <path d="M22 4 Q4 6 4 40 Q4 74 22 76" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
            </svg>
          </aside>

          <h2 class="featured-title">
            <a href={`/blog/${featuredPost.slug}/`}>{featuredPost.data.title}</a>
          </h2>

          {featuredPost.data.description && (
            <p class="featured-lede">{featuredPost.data.description}</p>
          )}

          <a href={`/blog/${featuredPost.slug}/`} class="featured-cta">
            <span class="cta-line"></span>Read the essay
          </a>

          <!-- the one handwritten aside on the page (besides the footer) -->
          <span class="featured-hand">Written between filter coffees.</span>
        </article>
      )}

      <!-- ============================================================
           Recent writing — editorial index, not a card grid
           ============================================================ -->
      {morePosts.length > 0 && (
        <section class="index">
          <header class="index-head">
            <span class="index-label">More writing</span>
          </header>

          <ol class="index-list">
            {morePosts.map(post => (
              <li class="index-row">
                <span class="ix-date">{fmtShort(post.data.publishDate)}</span>
                <a href={`/blog/${post.slug}/`} class="ix-title">{post.data.title}</a>
              </li>
            ))}
          </ol>

          <a href="/writing" class="index-more">The full archive</a>
        </section>
      )}
    </div>
  </div>

  <!-- ============================================================
       II. SUPPORTING ACTS — marginalia, trails, projects
       Three quieter sections, deliberately compressed.
       ============================================================ -->
  <div class="wrap">
    <div class="col">

      <!-- ---- Marginalia ---- -->
      <section class="quiet quiet--marginalia">
        <header class="quiet-head">
          <span class="quiet-eyebrow">Notebook</span>
          <h3 class="quiet-title">Marginalia</h3>
          <span class="quiet-sub">Half-formed things, kept on purpose.</span>
        </header>

        <div class="notes">
          {updates.map(async (update) => {
            const { Content } = await update.render();
            return (
              <article class="note">
                <span class="note-date">{fmtShort(update.data.publishDate)}</span>
                <div class="note-body">
                  {update.data.category === 'voice' && (
                    <span class="note-voice" aria-label="voice memo">
                      <span class="v"></span><span class="v"></span><span class="v"></span><span class="v"></span><span class="v"></span><span class="v"></span><span class="v"></span>
                    </span>
                  )}
                  <Content />
                </div>
              </article>
            );
          })}
        </div>

        <a href="/marginalia" class="quiet-more">More marginalia</a>
      </section>

      <!-- ---- Trails ---- -->
      {rssItems.length > 0 && (
        <section class="quiet quiet--trails">
          <header class="quiet-head">
            <span class="quiet-eyebrow">Reading</span>
            <h3 class="quiet-title">Trails</h3>
            <span class="quiet-sub">Where I've been clicking lately.</span>
          </header>

          <ul class="trails">
            {rssItems.map((item) => (
              <li class="trail">
                <a href={item.link}>
                  <span class="tr-source">{item.source}</span>
                  <span class="tr-title">{item.title}</span>
                </a>
              </li>
            ))}
          </ul>

          <a href="/trails" class="quiet-more">The whole thicket</a>
        </section>
      )}

      <!-- ---- Projects ---- -->
      <section class="quiet quiet--projects">
        <header class="quiet-head">
          <span class="quiet-eyebrow">Workshop</span>
          <h3 class="quiet-title">Things I've built</h3>
          <span class="quiet-sub">Mostly to scratch my own itches.</span>
        </header>

        <div class="projects">
          {projects.map(project => (
            <article class="project">
              <h4 class="pr-name">
                <a href={project.data.link || '#'}>{project.data.title}</a>
              </h4>
              {project.data.url && (
                <span class="pr-url">{project.data.url}</span>
              )}
              <p class="pr-desc">{project.data.description}</p>
            </article>
          ))}
        </div>

        <a href="/projects" class="quiet-more">All the projects</a>
      </section>

    </div>
  </div>

  <!-- ============================================================
       Interstitial — CSS-only quote rotator. Each quote fades in
       for ~7s, total cycle is N * 8s. prefers-reduced-motion
       falls back to a single static quote.
       ============================================================ -->
  <div class="wrap">
    <div class="col">
      <section class="rotator" style={`--rot-count: ${quotes.length}; --rot-step: 8s;`} aria-label="A rotating quotation">
        <div class="rot-rule"></div>
        <div class="rot-stage">
          {quotes.map((q, i) => (
            <figure class="rot-quote" style={`--i: ${i};`}>
              <blockquote>{q.text}</blockquote>
              <figcaption>&mdash; {q.by}</figcaption>
            </figure>
          ))}
        </div>
        <div class="rot-rule"></div>
      </section>
    </div>
  </div>

  <!-- ============================================================
       III. BOOKS — second headline act
       Featured book gets a real cover treatment with the pull
       quote running beside it. Three siblings on a shelf below,
       with deliberately uneven baselines so they feel arranged.
       ============================================================ -->
  {featuredBook && (
    <div class="wrap">
      <div class="col">
        <section class="library">
          <header class="library-head">
            <span class="quiet-eyebrow">The Stack</span>
            <h3 class="library-title">A small library</h3>
            <span class="quiet-sub">What's been worth the time.</span>
          </header>

          <!-- Featured book: cover + pull quote -->
          <article class="featured-book">
            <a href={`/books/${featuredBook.slug}/`} class="fb-cover-link">
              <div
                class="fb-cover"
                style={`--cover-bg: ${(coverStyles[featuredBook.data.coverColor] || coverStyles.flame).bg}; --cover-spine: ${(coverStyles[featuredBook.data.coverColor] || coverStyles.flame).spine};`}
              >
                <div class="fb-cover-inner">
                  <span class="fb-cover-author">{featuredBook.data.author}</span>
                  <span class="fb-cover-title">{featuredBook.data.title}</span>
                </div>
              </div>
            </a>

            <div class="fb-text">
              <span class="fb-kicker">Most recent</span>
              <h4 class="fb-title">
                <a href={`/books/${featuredBook.slug}/`}>{featuredBook.data.title}</a>
              </h4>
              <span class="fb-author">by {featuredBook.data.author}</span>
              {featuredBook.data.pull && (
                <blockquote class="fb-pull">{featuredBook.data.pull}</blockquote>
              )}
            </div>
          </article>

          <!-- Sibling books on a shelf -->
          {otherBooks.length > 0 && (
            <div class="shelf">
              {otherBooks.map((book, i) => {
                const color = book.data.coverColor || colorKeys[(i + 1) % colorKeys.length];
                const style = coverStyles[color] || coverStyles.flame;
                // Slight baseline variation: book 0 sits flush, 1 nudged down,
                // 2 nudged up. Real shelves are never perfectly even.
                const offsets = ['0px', '6px', '-4px'];
                return (
                  <a
                    href={`/books/${book.slug}/`}
                    class="sh-book"
                    style={`--cover-bg: ${style.bg}; --cover-spine: ${style.spine}; --baseline: ${offsets[i] || '0px'};`}
                  >
                    <div class="sh-cover">
                      <div class="sh-cover-inner">
                        <span class="sh-author">{book.data.author}</span>
                        <span class="sh-title">{book.data.title}</span>
                      </div>
                    </div>
                    <span class="sh-meta">{book.data.title}</span>
                  </a>
                );
              })}
            </div>
          )}

          <a href="/books" class="quiet-more">The whole library</a>
        </section>
      </div>
    </div>
  )}

  <!-- ============================================================
       Footer
       ============================================================ -->
  <div class="wrap">
    <div class="col">
      <Footer hand="What kind of sociopath reads footer text? Oh wait, you just did." />
    </div>
  </div>
</Layout>

<style>
  /* ================================================================
     HOMEPAGE — folio re-pace
     Intent: real hierarchy, deliberate use of the side margin,
     scale jumps that create life, restraint with handwritten type.
     ================================================================ */

  /* ---- shared utilities ---- */
  .col { position: relative; } /* anchor margin elements */

  /* ===== MASTHEAD ============================================== */
  .masthead {
    padding: 4.5rem 0 2.5rem;
    text-align: center;
    position: relative;
  }

  .masthead-hero {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    margin-bottom: 0.4rem;
  }

  /* Photo: matted in a paper "ring", slight hand-placed tilt that
     straightens on hover. Subtle and editorial. */
  .masthead-photo {
    width: 84px;
    height: 84px;
    border-radius: 50%;
    object-fit: cover;
    border: 1px solid var(--rule);
    padding: 3px;
    background: var(--paper);
    box-shadow: 0 2px 14px rgba(0, 0, 0, 0.06);
    flex-shrink: 0;
    transform: rotate(-1.8deg);
    transition: transform 0.6s var(--ease);
  }
  .masthead-hero:hover .masthead-photo {
    transform: rotate(0deg);
  }

  /* A double-rule chapter break beneath the nameplate row.
     Two short hairlines, 4px apart — quiet, distinctly editorial. */
  .masthead-rule {
    width: 36px;
    height: 5px;
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    margin: 1.1rem auto 1.4rem;
  }

  /* Section-break between the (centered) masthead and the
     (left-aligned) reading content. Thin, centered, restrained. */
  .masthead-break {
    width: 40px;
    height: 1px;
    background: var(--ink-ghost);
    margin: 0.8rem auto 0;
  }

  .nameplate {
    font-family: var(--serif);
    font-size: clamp(3.4rem, 6.8vw, 4.6rem);
    font-weight: 300;
    line-height: 0.92;
    letter-spacing: -0.04em;
    color: var(--ink);
    font-variation-settings: 'opsz' 144;
    font-feature-settings: 'kern', 'liga', 'dlig';
    margin: 0;
  }
  .np-stop {
    color: var(--flame);
    font-style: italic;
    font-weight: 400;
    margin-left: -0.04em;
  }

  .strapline {
    font-family: var(--serif);
    font-size: clamp(0.98rem, 1.7vw, 1.12rem);
    font-style: italic;
    font-weight: 300;
    line-height: 1.6;
    color: var(--ink-soft);
    max-width: 40ch;
    margin: 0 auto;
    font-variation-settings: 'opsz' 24;
    text-wrap: pretty;
  }

  /* Colophon: day / now / made rows. Labels in italic small caps,
     descriptors in upright serif so the rows don't blur with the
     italic strapline above. */
  .bio {
    margin: 1.9rem auto 0;
    max-width: 540px;
    text-align: left;
    padding-top: 0.2rem;
  }
  .bio-row {
    display: grid;
    grid-template-columns: 64px 1fr;
    align-items: baseline;
    column-gap: 1.6rem;
    padding: 0.4rem 0;
  }
  .bio dt {
    font-family: var(--serif);
    font-feature-settings: 'smcp', 'c2sc', 'kern';
    text-transform: lowercase;
    font-style: italic;
    font-weight: 400;
    font-size: 0.96rem;
    letter-spacing: 0.05em;
    color: var(--ink-light);
    text-align: right;
  }
  .bio dd {
    font-family: var(--serif);
    font-size: 1rem;
    font-weight: 400;
    line-height: 1.6;
    color: var(--ink-mid);
    font-variation-settings: 'opsz' 16;
    text-wrap: pretty;
  }
  .bio dd a {
    color: var(--ink);
    text-decoration: none;
    background-image: linear-gradient(var(--rule), var(--rule));
    background-repeat: no-repeat;
    background-size: 100% 1px;
    background-position: 0 100%;
    transition: color 0.2s, background-image 0.3s;
  }
  .bio dd a:hover {
    color: var(--flame);
    background-image: linear-gradient(var(--flame-line), var(--flame-line));
  }
  .bio-made a {
    color: var(--ink-mid);
  }
  .bio-made .sep {
    color: var(--ink-ghost);
    margin: 0 0.5rem 0 0.1rem;
  }

  /* ===== I. FEATURED ESSAY ===================================== */
  .featured {
    position: relative;
    padding: 6rem 0 4rem;
  }

  /* left margin element — visible only on wide screens */
  .featured-meta {
    position: absolute;
    right: calc(100% + var(--gap));
    top: 6.4rem;
    width: var(--margin);
    text-align: right;
    color: var(--ink-light);
  }
  .fm-kicker {
    display: block;
    font-family: var(--mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--flame);
    margin-bottom: 0.9rem;
    font-weight: 500;
  }
  .fm-date {
    display: block;
    font-family: var(--serif);
    font-size: 1rem;
    font-style: italic;
    font-weight: 300;
    color: var(--ink-mid);
    line-height: 1.4;
  }
  .fm-time {
    display: block;
    font-family: var(--mono);
    font-size: 0.74rem;
    color: var(--ink-light);
    letter-spacing: 0.04em;
    margin-top: 0.4rem;
  }
  .fm-bracket {
    width: 22px;
    height: 64px;
    color: var(--flame-line);
    margin: 1.4rem 0 0 auto;
    display: block;
  }

  .featured-title {
    font-family: var(--serif);
    font-size: clamp(2rem, 4.2vw, 3rem);
    font-weight: 300;
    line-height: 1.06;
    letter-spacing: -0.026em;
    color: var(--ink);
    font-variation-settings: 'opsz' 72;
    text-wrap: balance;
    margin-bottom: 1.6rem;
  }
  .featured-title a {
    color: inherit;
    text-decoration: none;
    background-image: linear-gradient(var(--flame-line), var(--flame-line));
    background-repeat: no-repeat;
    background-size: 0% 1px;
    background-position: 0 100%;
    transition: background-size 0.5s var(--ease);
  }
  .featured-title a:hover {
    background-size: 100% 1px;
  }

  .featured-lede {
    font-family: var(--serif);
    font-size: 1.12rem;
    font-style: italic;
    font-weight: 300;
    line-height: 1.65;
    color: var(--ink-soft);
    max-width: 56ch;
    font-variation-settings: 'opsz' 24;
    text-wrap: pretty;
    margin-bottom: 1.8rem;
  }

  /* CTA — a hairline that becomes a line of type */
  .featured-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    font-family: var(--mono);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--ink);
    text-decoration: none;
    transition: color 0.3s, gap 0.3s;
    font-weight: 500;
  }
  .cta-line {
    display: inline-block;
    width: 28px;
    height: 1px;
    background: var(--ink);
    transition: width 0.3s var(--ease), background 0.3s;
  }
  .featured-cta:hover { color: var(--flame); gap: 0.95rem; }
  .featured-cta:hover .cta-line { width: 44px; background: var(--flame); }

  /* the one handwritten flourish on the homepage */
  .featured-hand {
    position: absolute;
    right: -0.5rem;
    bottom: 4.4rem;
    font-family: var(--hand);
    font-size: 1.15rem;
    color: var(--flame-warm);
    transform: rotate(-1.5deg);
    max-width: 180px;
    text-align: center;
    line-height: 1.2;
  }
  .featured-hand::before {
    content: '';
    display: block;
    width: 38px;
    height: 1px;
    background: var(--flame-line);
    margin: 0 auto 0.35rem;
    transform: rotate(-2deg);
  }

  /* ===== Recent writing — editorial index ===================== */
  .index {
    margin-top: 1.5rem;
    padding-top: 2.2rem;
    border-top: 1px solid var(--rule-faint);
  }
  .index-head { margin-bottom: 1.4rem; }
  .index-label {
    font-family: var(--mono);
    font-size: 0.74rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--ink-light);
    font-weight: 500;
  }
  .index-list {
    list-style: none;
    padding: 0;
    margin: 0;
    border-top: 1px solid var(--rule-faint);
  }
  .index-row {
    display: grid;
    grid-template-columns: 64px 1fr;
    align-items: baseline;
    gap: 1.2rem;
    padding: 1rem 0;
    border-bottom: 1px solid var(--rule-faint);
    transition: padding 0.3s var(--ease);
  }
  .index-row:hover { padding-left: 0.4rem; }
  .ix-date {
    font-family: var(--mono);
    font-size: 0.74rem;
    color: var(--ink-light);
    letter-spacing: 0.04em;
  }
  .ix-title {
    font-family: var(--serif);
    font-size: 1.1rem;
    font-weight: 400;
    line-height: 1.35;
    color: var(--ink);
    text-decoration: none;
    text-wrap: balance;
    transition: color 0.2s;
  }
  .ix-title:hover { color: var(--flame); }
  .ix-tag {
    font-family: var(--serif);
    font-style: italic;
    font-size: 0.92rem;
    color: var(--ink-light);
    font-variation-settings: 'opsz' 14;
    white-space: nowrap;
  }
  .index-more {
    display: inline-block;
    margin-top: 1.8rem;
    font-family: var(--mono);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--ink-mid);
    text-decoration: none;
    border-bottom: 1px solid var(--rule);
    padding-bottom: 0.2rem;
    transition: color 0.2s, border-color 0.2s;
    font-weight: 500;
  }
  .index-more:hover { color: var(--flame); border-color: var(--flame); }

  /* ===== II. QUIET SECTIONS =================================== */
