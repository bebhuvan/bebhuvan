    font-size: 0.74rem;
    color: var(--ink-light);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 500;
  }

  /* Each quote: window = 1/N of cycle. With 5 quotes that's 20%.
     0–3% fade in, 3–17% hold, 17–20% fade out. The next quote starts
     its fade-in exactly when this one finishes its fade-out. */
  @keyframes rot-cycle {
    0%   { opacity: 0; transform: translateY(8px); }
    3%   { opacity: 1; transform: translateY(0); }
    17%  { opacity: 1; transform: translateY(0); }
    20%  { opacity: 0; transform: translateY(-6px); }
    100% { opacity: 0; transform: translateY(-6px); }
  }

  /* Reduced motion: just show the first quote, statically. */
  @media (prefers-reduced-motion: reduce) {
    .rot-quote { animation: none; opacity: 0; }
    .rot-quote:first-child { opacity: 1; position: relative; }
    .rot-quote:not(:first-child) { display: none; }
    .rot-stage { min-height: 0; }
