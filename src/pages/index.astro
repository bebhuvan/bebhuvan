    position: relative;
  }
  .rot-rule {
    width: 40px;
    height: 1px;
    background: var(--ink-ghost);
    margin: 0 auto;
  }
  .rot-stage {
    position: relative;
    margin: 2.4rem auto;
    /* reserve enough vertical room for the longest quote */
    min-height: 11rem;
    max-width: 560px;
  }
  .rot-quote {
    position: absolute;
    inset: 0;
    margin: 0;
    opacity: 0;
    animation: rot-cycle calc(var(--rot-count) * var(--rot-step)) infinite ease-in-out;
    animation-delay: calc(var(--i) * var(--rot-step));
    will-change: opacity, transform;
  }
  .rot-quote blockquote {
    font-family: var(--serif);
    font-size: clamp(1.25rem, 2.4vw, 1.7rem);
    font-weight: 300;
    font-style: italic;
    line-height: 1.5;
