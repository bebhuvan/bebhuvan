---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import PageHeader from '../components/PageHeader.astro';
import ProjectIcon from '../components/ProjectIcon.astro';

const projects = (await getCollection('projects'))
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));

const marginNotes: Record<string, string> = {
  "Seneca's Letters": "2000-year-old advice that slaps harder than most self-help published this year",
  "Paper Lanterns": "named after the idea that old words can still light up the dark",
  "Paper Trails": "do people still use RSS? just me? okay cool",
};

const iconMap: Record<string, string> = {
  "Seneca's Letters": "scroll-text",
  "Akshara": "languages",
  "Paper Lanterns": "lamp",
  "Rabbit Holes": "rabbit",
  "Dhawani": "mic",
  "Paper Trails": "rss",
  "From The Dumpster Fire": "fire",
  "Collections": "sparkles",
};
---

<Layout title="Projects — Bhuvan" description="Things I build — mostly for myself, occasionally useful to others.">
  <Nav active="projects" />

  <div class="wrap">
    <div class="col">
      <PageHeader
        numeral="IV"
        title='Things I <em>Build</em>'
        subtitle="mostly for myself, occasionally useful to others — every project is really an excuse to learn something"
      />

      {projects.map(async (project) => {
        const { Content } = await project.render();
        const iconName = iconMap[project.data.title] || 'sparkles';
        const margin = marginNotes[project.data.title];
        return (
          <div class="project">
            <div class="p-icon">
              <ProjectIcon name={iconName} size={28} />
            </div>
            <div>
              <div class="p-name"><a href={project.data.link || '#'}>{project.data.title}</a></div>
              {project.data.url && <span class="p-url">{project.data.url}</span>}
              <div class="p-desc">{project.data.description}</div>
              <div class="p-story">
                <Content />
              </div>
              {project.data.story && (
                <span class="p-hand">&larrhk; {project.data.story}</span>
              )}
              {margin && <div class="p-aside">&larrhk; {margin}</div>}
            </div>
          </div>
        );
      })}

      <Footer
        meta='Zerodha &middot; Bangalore &middot; The Internet<br>6 projects and counting. All of them started as &ldquo;just a weekend thing.&rdquo;'
        hand="The best projects are the ones that were never supposed to be projects."
      />
    </div>
  </div>
</Layout>

<style>
  .project {
    padding: 2rem 0 2rem 1rem;
    margin-left: -1rem;
    border-bottom: 1px solid var(--rule-faint);
    border-left: 2px solid transparent;
    display: grid;
    grid-template-columns: 40px 1fr;
    gap: 1.2rem;
    align-items: start;
    transition: border-left-color 0.25s var(--ease);
  }
  .project:hover { border-left-color: var(--flame-line); }
  .project:last-of-type { border-bottom: none; }

  .p-icon {
    font-size: 1.8rem; line-height: 1;
    transition: transform 0.3s var(--ease);
  }
  .project:hover .p-icon { transform: scale(1.1) rotate(-3deg); }

  .p-name {
    font-family: var(--serif); font-size: 1.12rem; font-weight: 500;
    color: var(--ink); letter-spacing: -0.015em; margin-bottom: 0.1rem;
    font-variation-settings: 'opsz' 28;
  }
  .p-name a { color: inherit; text-decoration: none; border-bottom: 1px solid transparent; transition: color 0.2s, border-color 0.2s; }
  .p-name a:hover { color: var(--flame); border-color: var(--flame-line); }

  .p-url {
    font-family: var(--mono); font-size: 0.58rem; color: var(--flame);
    display: block; margin-bottom: 0.5rem; letter-spacing: 0.02em;
  }

  .p-desc {
    font-family: var(--serif); font-size: 0.92rem; font-weight: 300;
    color: var(--ink-soft); line-height: 1.65; margin-bottom: 1rem; max-width: 520px;
    font-variation-settings: 'opsz' 14;
  }

  .p-story :global(p) {
    font-family: var(--serif); font-size: 0.88rem; font-weight: 300;
    font-style: italic; color: var(--ink-light); line-height: 1.7;
    border-left: 2px solid var(--flame-line); padding-left: 1rem;
    max-width: 480px; margin-bottom: 0.8rem;
    font-variation-settings: 'opsz' 14;
  }

  .p-hand {
    font-family: var(--hand); font-size: 1.1rem; color: var(--flame-warm);
    display: inline-block; transform: rotate(-0.5deg);
  }

  /* Inline aside — replaces absolute-positioned margin notes */
  .p-aside {
    font-family: var(--hand); font-size: 1.05rem; color: var(--ink-light);
    margin-top: 0.8rem; line-height: 1.4;
    padding: 0.5rem 0 0.5rem 0.8rem;
    border-left: 2px solid var(--flame-line);
    transform: rotate(-0.3deg);
    display: inline-block;
  }

  @media (max-width: 700px) {
    .project { gap: 1rem; grid-template-columns: 36px 1fr; }
    .p-icon { font-size: 1.5rem; }
  }
</style>
