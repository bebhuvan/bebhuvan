---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Interstitial from '../components/Interstitial.astro';
import ProjectIcon from '../components/ProjectIcon.astro';
import { aggregateRSSFeeds } from '../utils/rss-aggregator';

const blogPosts = (await getCollection('blog'))
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

const featuredPost = blogPosts[0];
const morePosts = blogPosts.slice(1, 5);

const updates = (await getCollection('updates'))
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 3);

const projects = (await getCollection('projects'))
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99))
  .slice(0, 3);

let books: any[] = [];
try {
  books = (await getCollection('books'))
    .sort((a, b) => (b.data.year ?? 0) - (a.data.year ?? 0))
    .slice(0, 4);
} catch (e) {}

let rssItems: any[] = [];
try {
  rssItems = (await aggregateRSSFeeds(4));
} catch (e) {}

const iconMap: Record<string, string> = {
  "Seneca's Letters": "scroll-text",
  "Akshara": "languages",
  "Paper Lanterns": "lamp",
  "Rabbit Holes": "rabbit",
  "Dhawani": "mic",
  "Paper Trails": "rss",
  "From The Dumpster Fire": "fire",
  "Collections": "sparkles",
};

const coverStyles: Record<string, { bg: string; spine: string }> = {
  flame: {
    bg: 'linear-gradient(170deg, #B84430 0%, #C45638 45%, #9A3A28 100%)',
    spine: '#7A2E1E',
  },
  blue: {
    bg: 'linear-gradient(170deg, #2E4B78 0%, #3D6098 45%, #253E68 100%)',
    spine: '#1C3050',
  },
  green: {
    bg: 'linear-gradient(170deg, #336B45 0%, #448B5A 45%, #2A5838 100%)',
    spine: '#1E4030',
  },
  gold: {
    bg: 'linear-gradient(170deg, #8B6E35 0%, #A8864A 45%, #73592A 100%)',
    spine: '#5A4520',
  },
};
const colorKeys = ['flame', 'blue', 'green', 'gold'];
---

<Layout title="Bhuvan — The Folio">
  <Nav />

  <!-- ===== OPENING + WRITING ===== -->
  <div class="wrap">
    <div class="col">

      <section class="opening">
        <div class="opening-hero">
          <img src="/blog-images/Bhuvan profile pic.webp" alt="Bhuvan" class="opening-photo" width="88" height="88" />
          <h1 class="nameplate">Bhuvan<em>.</em></h1>
        </div>
        <p class="strapline">Doer of random things. Diver of weird rabbit holes.<br />Sharer of weird and fascinating things. Writer of things nobody reads.</p>

        <div class="opening-rule"></div>

        <div class="details">
          <div class="detail-row">
            <span class="detail-label">work</span>
            <span class="detail-value"><a href="https://zerodha.com">Zerodha</a> — markets, data, thinking about curation</span>
          </div>
          <div class="detail-row">
            <span class="detail-label">now</span>
            <span class="detail-value">OCR pipeline for 1860s Kannada texts at <a href="https://akshara.ink">Akshara</a>. Reading Borges again.</span>
          </div>
          <div class="detail-row">
            <span class="detail-label">made</span>
            <span class="detail-value">
              <span class="detail-links">
                {projects.map((p, i) => (
                  <>
                    <a href={p.data.link || '#'}>{p.data.url || p.data.title}</a>
                    {i < projects.length - 1 && <span class="link-sep">&middot;</span>}
                  </>
                ))}
              </span>
            </span>
          </div>
        </div>
        <span class="opening-hand">ideas, loose threads, and the occasional rabbit hole</span>
      </section>

      <!-- ===== WRITING (I) ===== -->
      <section class="sec">
        <header class="sec-header">
          <span class="sec-num">I</span>
          <h2 class="sec-title">Writing</h2>
        </header>

        {featuredPost && (
          <div class="essay-featured">
            <div class="ef-meta">
              {featuredPost.data.publishDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
              {featuredPost.data.readingTime && ` · ${featuredPost.data.readingTime}`}
              <span class="ef-badge">latest</span>
            </div>
            <h3 class="ef-title">
              <a href={`/blog/${featuredPost.slug}/`}>{featuredPost.data.title}</a>
            </h3>
            {featuredPost.data.description && (
              <p class="ef-body">{featuredPost.data.description}</p>
            )}
            <a href={`/blog/${featuredPost.slug}/`} class="ef-read">Read the essay &rarr;</a>
          </div>
        )}

        {morePosts.map(post => (
          <div class="essay-row">
            <a href={`/blog/${post.slug}/`} class="er-title">{post.data.title}</a>
            <span class="er-meta">
              {post.data.publishDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}
              {post.data.tags?.[0] && <span class="er-tag"> · {post.data.tags[0]}</span>}
            </span>
          </div>
        ))}

        <a href="/writing" class="sec-more">See all writing &rarr;</a>
      </section>

      <!-- ===== INTERSTITIAL (Seneca) ===== -->
      <Interstitial
        quote="It is not that we have a short time to live, but that we waste a great deal of it."
        attribution="Seneca, Letter I · from seneca.ink"
        annotation="built a whole website for this guy ↗"
      />

    </div>
  </div>

  <!-- ===== NOTES (II) ===== -->
  <div class="wrap">
    <div class="col">
      <section class="sec">
        <header class="sec-header">
          <span class="sec-num">II</span>
          <h2 class="sec-title">Marginalia</h2>
        </header>

        {updates.map(async (update) => {
          const { Content } = await update.render();
          return (
            <div class="note">
              <div class="note-header">
                <span class="note-time">{update.data.publishDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}</span>
                {update.data.category === 'voice' && (
                  <span class="note-voice">
                    <span class="v"></span><span class="v"></span><span class="v"></span><span class="v"></span><span class="v"></span>
                  </span>
                )}
                {update.data.category && <span class="note-cat">{update.data.category}</span>}
              </div>
              <div class="note-body">
                <Content />
              </div>
            </div>
          );
        })}

        <a href="/marginalia" class="sec-more">See all marginalia &rarr;</a>
      </section>

      <!-- ===== TRAILS (III) + PROJECTS (IV) ===== -->

      {rssItems.length > 0 && (
        <section class="sec">
          <header class="sec-header">
            <span class="sec-num">III</span>
            <h2 class="sec-title">Trails</h2>
          </header>

          <div class="trails-list">
            {rssItems.map((item, i) => (
              <a href={item.link} class="trail">
                <span class="trail-num">{String(i + 1).padStart(2, '0')}</span>
                <div class="trail-content">
                  <span class="trail-source">{item.source}</span>
                  <span class="trail-title">{item.title}</span>
                </div>
              </a>
            ))}
          </div>

          <a href="/trails" class="sec-more">See all trails &rarr;</a>
        </section>
      )}

      <section class="sec">
        <header class="sec-header">
          <span class="sec-num">IV</span>
          <h2 class="sec-title">Projects</h2>
        </header>

        {projects.map(project => (
          <div class="proj">
            <div class="proj-icon">
              <ProjectIcon name={iconMap[project.data.title] || 'sparkles'} size={28} />
            </div>
            <div>
              <div class="proj-name"><a href={project.data.link || '#'}>{project.data.title}</a></div>
              {project.data.url && <span class="proj-url">{project.data.url}</span>}
              <div class="proj-desc">{project.data.description}</div>
              {project.data.story && (
                <span class="proj-hand">&larrhk; {project.data.story}</span>
              )}
            </div>
          </div>
        ))}

        <a href="/projects" class="sec-more">See all projects &rarr;</a>
      </section>

    </div>
  </div>

  <!-- ===== INTERSTITIAL (Borges) ===== -->
  <div class="wrap">
    <div class="col">
      <Interstitial
        quote="I have always imagined that Paradise will be a kind of library."
        attribution="Borges, Ficciones"
        annotation="same, honestly"
      />
    </div>
  </div>

  <!-- ===== BOOKS (V) ===== -->
  {books.length > 0 && (
    <div class="wrap">
      <div class="col">
        <section class="sec">
          <header class="sec-header">
            <span class="sec-num">V</span>
            <h2 class="sec-title">Books</h2>
          </header>

          <div class="books-grid">
            {books.map((book, i) => {
              const color = book.data.coverColor || colorKeys[i % colorKeys.length];
              const style = coverStyles[color] || coverStyles.flame;
              return (
                <a href={`/books/${book.slug}/`} class="book-card">
                  <div class="bc-cover" style={`--cover-bg: ${style.bg}; --cover-spine: ${style.spine};`}>
                    <div class="bc-cover-inner">
                      <span class="bc-cover-author">{book.data.author}</span>
                      <span class="bc-cover-title">{book.data.title}</span>
                    </div>
                  </div>
                  <div class="bc-meta">
                    <span class="bc-title">{book.data.title}</span>
                    {book.data.pull && (
                      <span class="bc-pull">{book.data.pull}</span>
                    )}
                  </div>
                </a>
              );
            })}
          </div>

          <a href="/books" class="sec-more">See all books &rarr;</a>
        </section>
      </div>
    </div>
  )}

  <div class="wrap">
    <div class="col">
      <Footer hand="What kind of sociopath reads footer text? Oh wait, you just did." />
    </div>
  </div>
</Layout>

<style>
  /* ===== OPENING ===== */
  .opening {
    padding: 8.5rem 0 2rem;
    text-align: center;
  }

  .opening-hero {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.4rem;
    margin-bottom: 0.9rem;
  }

  .opening-photo {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    object-fit: cover;
    box-shadow: 0 2px 12px rgba(0,0,0,0.07);
    flex-shrink: 0;
  }

  .nameplate {
    font-family: var(--serif);
    font-size: clamp(3.8rem, 7.5vw, 5.2rem);
    font-weight: 700;
    line-height: 0.9;
    letter-spacing: -0.045em;
    color: var(--ink);
    font-variation-settings: 'opsz' 72;
  }

  .nameplate em {
    font-style: normal;
    color: var(--flame);
    font-size: 1.1em;
  }

  .strapline {
    font-family: var(--serif);
    font-size: clamp(0.98rem, 1.6vw, 1.12rem);
    font-weight: 300;
    font-style: italic;
    color: var(--ink-soft);
    line-height: 1.6;
    font-variation-settings: 'opsz' 20;
  }

  .opening-rule {
    width: 40px;
    height: 1px;
    background: var(--ink-ghost);
    margin: 2rem auto 1.6rem;
  }

  .details {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    text-align: left;
    max-width: 440px;
    margin: 0 auto;
  }

  .detail-row {
    display: flex;
    align-items: baseline;
    gap: 0.9rem;
  }

  .detail-label {
    font-family: var(--hand);
    font-size: 1.05rem;
    color: var(--ink-light);
    width: 48px;
    flex-shrink: 0;
    transform: rotate(-0.3deg);
    display: inline-block;
  }

  .detail-value {
    font-family: var(--serif);
    font-size: 0.9rem;
    font-weight: 300;
    color: var(--ink-soft);
    line-height: 1.55;
    font-variation-settings: 'opsz' 16;
  }

  .detail-value a {
    color: var(--ink-mid);
    text-decoration: none;
    border-bottom: 1px solid var(--rule);
    transition: color 0.2s, border-color 0.2s;
  }

  .detail-value a:hover {
    color: var(--flame);
    border-color: var(--flame-line);
  }

  .detail-links {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.3rem 0;
  }

  .detail-links a {
    font-family: var(--mono);
    font-size: 0.6rem;
    color: var(--ink-light);
    text-decoration: none;
    border-bottom: 1px solid var(--rule-faint);
    padding-bottom: 0.05em;
    transition: color 0.2s, border-color 0.2s;
  }

  .detail-links a:hover {
    color: var(--flame);
    border-color: var(--flame-line);
  }

  .link-sep {
    font-family: var(--mono);
    font-size: 0.6rem;
    color: var(--ink-ghost);
    margin: 0 0.35rem;
    user-select: none;
  }

  .opening-hand {
    font-family: var(--hand);
    font-size: 1.05rem;
    color: var(--ink-light);
    display: block;
    margin-top: 1.5rem;
    text-align: center;
    transform: rotate(-0.5deg);
  }

  /* ===== SECTIONS ===== */
  .sec {
    margin-top: 4.5rem;
    padding-top: 2rem;
    position: relative;
  }

  .sec::before {
    content: '';
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 40px;
    height: 1px;
    background: var(--ink-ghost);
  }

  .sec-header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .sec-num {
    font-family: var(--serif);
    font-size: 1.6rem;
    font-weight: 200;
    color: var(--rule);
    letter-spacing: -0.04em;
    display: block;
    line-height: 1;
    margin-bottom: 0.3rem;
  }

  .sec-title {
    font-family: var(--serif);
    font-size: clamp(1.4rem, 2.5vw, 1.7rem);
    font-weight: 300;
    color: var(--ink);
    letter-spacing: -0.03em;
    line-height: 1.1;
    font-variation-settings: 'opsz' 48;
  }

  .sec-more {
    font-family: var(--mono);
    font-size: 0.62rem;
    color: var(--ink-soft);
    text-decoration: none;
    display: block;
    text-align: center;
    margin-top: 2rem;
    transition: color 0.2s;
  }

  .sec-more:hover {
    color: var(--flame);
  }

  /* ===== FEATURED ESSAY ===== */
  .essay-featured {
    padding: 0 0 2.5rem;
    margin-bottom: 0.5rem;
    border-bottom: 1px solid var(--rule);
  }

  .ef-meta {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    font-family: var(--mono);
    font-size: 0.6rem;
    color: var(--ink-faint);
    margin-bottom: 1.2rem;
  }

  .ef-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.55rem;
    font-weight: 500;
    color: var(--flame);
    background: var(--flame-wash);
    padding: 0.12rem 0.5rem;
    border-radius: 3px;
  }

  .ef-badge::before {
    content: '';
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--flame);
    animation: pulse 2s ease infinite;
  }

  .ef-title {
    font-family: var(--serif);
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    font-weight: 400;
    line-height: 1.18;
    letter-spacing: -0.025em;
    margin-bottom: 1.4rem;
    font-variation-settings: 'opsz' 48;
  }

  .ef-title a {
    color: var(--ink);
    text-decoration: none;
    transition: color 0.2s;
  }

  .ef-title a:hover {
    color: var(--flame);
  }

  .ef-body {
    font-family: var(--serif);
    font-size: 0.95rem;
    font-weight: 300;
    font-style: italic;
    line-height: 1.78;
    color: var(--ink-soft);
    border-left: 2px solid var(--flame-line);
    padding-left: 1.2rem;
    max-width: 500px;
    margin-bottom: 1.4rem;
  }

  .ef-read {
    font-family: var(--mono);
    font-size: 0.62rem;
    color: var(--flame);
    text-decoration: none;
    transition: color 0.2s;
  }

  .ef-read:hover {
    color: var(--ink);
  }

  /* ===== ESSAY ROWS ===== */
  .essay-row {
    padding: 1.1rem 0;
    border-bottom: 1px solid var(--rule-faint);
  }

  .essay-row:last-child {
    border-bottom: none;
  }

  .er-title {
    font-family: var(--serif);
    font-size: 1.05rem;
    font-weight: 400;
    color: var(--ink);
    text-decoration: none;
    line-height: 1.35;
    letter-spacing: -0.01em;
    display: block;
    transition: color 0.2s;
    font-variation-settings: 'opsz' 16;
  }

  .er-title:hover {
    color: var(--flame);
  }

  .er-meta {
    font-family: var(--mono);
    font-size: 0.6rem;
    color: var(--ink-light);
    display: block;
    margin-top: 0.25rem;
  }

  .er-tag {
    font-family: var(--hand);
    font-size: 1.05rem;
    color: var(--ink-ghost);
  }

  /* ===== NOTES ===== */
  .note {
    border-left: 2px solid var(--flame-line);
    padding: 0.2rem 0 0.2rem 1.4rem;
    margin-bottom: 2.5rem;
    transition: border-left-color 0.2s;
  }

  .note:last-child {
    margin-bottom: 0;
  }

  .note:hover {
    border-left-color: var(--flame);
  }

  .note-header {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 0.5rem;
  }

  .note-time {
    font-family: var(--mono);
    font-size: 0.6rem;
    color: var(--ink-faint);
  }

  .note-voice {
    display: inline-flex;
    align-items: center;
    gap: 2px;
  }

  .note-voice .v {
    width: 2px;
    border-radius: 1px;
    background: var(--flame-warm);
    opacity: 0.5;
  }

  .note-voice .v:nth-child(1) { height: 4px; }
  .note-voice .v:nth-child(2) { height: 8px; }
  .note-voice .v:nth-child(3) { height: 12px; }
  .note-voice .v:nth-child(4) { height: 7px; }
  .note-voice .v:nth-child(5) { height: 3px; }

  .note-cat {
    font-family: var(--mono);
    font-size: 0.58rem;
    color: var(--ink-faint);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .note-body {
    font-family: var(--serif);
    font-size: 0.95rem;
    font-weight: 300;
    line-height: 1.75;
    color: var(--ink-mid);
  }

  .note-body :global(strong) { font-weight: 500; color: var(--ink); }
  .note-body :global(p) { margin: 0; }
  .note-body :global(p + p) { margin-top: 0.5rem; }
  .note-body :global(a) { color: var(--flame); text-decoration: none; }
  .note-body :global(blockquote) {
    font-style: italic;
    color: var(--ink-light);
    margin: 0.5rem 0;
    padding-left: 1rem;
    border-left: 2px solid var(--flame-line);
  }

  /* ===== TRAILS ===== */
  .trails-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .trail {
    display: grid;
    grid-template-columns: 2rem 1fr;
    gap: 0.8rem;
    align-items: baseline;
    padding: 1.1rem 0;
    border-bottom: 1px solid var(--rule-faint);
    text-decoration: none;
    transition: background 0.2s;
  }

  .trail:last-child {
    border-bottom: none;
  }

  .trail-num {
    font-family: var(--mono);
    font-size: 0.58rem;
    color: var(--ink-ghost);
    transition: color 0.2s;
  }

  .trail:hover .trail-num {
    color: var(--flame);
  }

  .trail-content {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .trail-source {
    font-family: var(--mono);
    font-size: 0.55rem;
    color: var(--ink-faint);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .trail-title {
    font-family: var(--serif);
    font-size: 1rem;
    font-weight: 400;
    color: var(--ink);
    line-height: 1.35;
    font-variation-settings: 'opsz' 20;
    transition: color 0.2s;
  }

  .trail:hover .trail-title {
    color: var(--flame);
  }

  /* ===== PROJECTS ===== */
  .proj {
    display: grid;
    grid-template-columns: 40px 1fr;
    gap: 1.2rem;
    align-items: start;
    padding: 2rem 0;
    border-bottom: 1px solid var(--rule-faint);
  }

  .proj:last-child {
    border-bottom: none;
  }

  .proj-icon {
    font-size: 1.8rem;
    line-height: 1;
    transition: transform 0.3s var(--ease);
  }

  .proj:hover .proj-icon {
    transform: scale(1.1) rotate(-3deg);
  }

  .proj-name {
    font-family: var(--serif);
    font-size: 1.12rem;
    font-weight: 500;
    color: var(--ink);
    letter-spacing: -0.015em;
    margin-bottom: 0.1rem;
    font-variation-settings: 'opsz' 28;
  }

  .proj-name a {
    color: inherit;
    text-decoration: none;
    transition: color 0.2s;
  }

  .proj-name a:hover {
    color: var(--flame);
  }

  .proj-url {
    font-family: var(--mono);
    font-size: 0.6rem;
    color: var(--flame);
    display: block;
    margin-bottom: 0.4rem;
  }

  .proj-desc {
    font-family: var(--serif);
    font-size: 0.92rem;
    font-weight: 300;
    color: var(--ink-soft);
    line-height: 1.65;
  }

  .proj-hand {
    font-family: var(--hand);
    font-size: 1.05rem;
    color: var(--flame-warm);
    display: inline-block;
    margin-top: 0.35rem;
    transform: rotate(-0.5deg);
  }

  /* ===== BOOKS GRID ===== */
  .books-grid {
    display: grid;
